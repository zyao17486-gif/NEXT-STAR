{
  "name": "next-star",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "vite build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "audit:dependencies": "npm audit --audit-level=high --registry=https://registry.npmjs.org/ && npm audit --prefix server --audit-level=high --registry=https://registry.npmjs.org/",
    "check:data": "node scripts/check-data-sync.mjs",
    "check:bundle": "node scripts/check-build-size.mjs",
    "check:server": "node --check server/index.js && node --check server/validation.js && node --check server/observability.js && node --check public/_worker.js",
    "check": "npm run audit:dependencies && npm run check:data && npm run typecheck && npm run test && npm run check:server && npm run build && npm run check:bundle",
    "dev": "vite",
    "sync:data": "node scripts/sync-server-db.mjs",
    "dev:server": "npm run sync:data && cd server && node --watch index.js",
    "dev:all": "start \"\" cmd /c \"npm run dev:server\" && vite"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.101.0",
    "motion": "12.23.24",
    "recharts": "2.15.2",
    "tw-animate-css": "1.3.8",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@tailwindcss/vite": "4.1.12",
    "@types/node": "^24.10.0",
    "@types/react": "^18.3.31",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "4.7.0",
    "tailwindcss": "4.1.12",
    "typescript": "^5.9.3",
    "vite": "^6.4.3",
    "vitest": "^4.1.10"
  },
  "peerDependencies": {
    "react": "18.3.1",
    "react-dom": "18.3.1"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    }
  }
}
